# Configuration de Soccer Analytics Platform

# =============================================================================
# CHEMINS ET REPERTOIRES
# =============================================================================

# Répertoire principal pour soccerdata (cache + config)
SOCCERDATA_DIR=/workspace/soccer_analytics/data

# Répertoire pour le cache des données téléchargées
SOCcerDATA_CACHE_DIR=/workspace/soccer_analytics/data/cache

# Répertoire pour les fichiers de configuration
SOCCERDATA_CONFIG_DIR=/workspace/soccer_analytics/config

# Base de données (SQLite pour dev, PostgreSQL pour prod)
DATABASE_URL=sqlite:///./data/soccer_analytics.db
# DATABASE_URL=postgresql://user:password@localhost:5432/soccer_analytics

# =============================================================================
# CONFIGURATION API
# =============================================================================

# Hôte et port pour l'API REST
API_HOST=0.0.0.0
API_PORT=8000

# Mode debug (désactiver en production)
DEBUG=true

# Authentification API (optionnel)
API_KEY_HEADER=X-API-Key
API_SECRET_KEY=votre_cle_secrete_ici_changer_en_production

# =============================================================================
# SOURCES DE DONNEES - CONFIGURATION SPECIFIQUE
# =============================================================================

# FBref
FBREF_MAX_RETRIES=3
FBREF_RETRY_DELAY=5  # secondes entre les retries
FBREF_TIMEOUT=30  # timeout en secondes

# WhoScored (nécessite Selenium)
WHOSCORED_USE_SELENIUM=true
WHOSCORED_HEADLESS=true
WHOSCORED_NO_SANDBOX=true
WHOSCORED_PROXY=  # laisser vide ou mettre proxy:port
WHOSCORED_MAX_RETRIES=3
WHOSCORED_RETRY_DELAY=10

# Sofascore
SOFASCORE_MAX_RETRIES=3
SOFASCORE_RETRY_DELAY=5

# ESPN
ESPN_MAX_RETRIES=3
ESPN_RETRY_DELAY=5

# MatchHistory (Football-Data.co.uk)
MATCHHISTORY_MAX_RETRIES=3
MATCHHISTORY_RETRY_DELAY=5

# ClubElo
CLUBELO_MAX_RETRIES=3
CLUBELO_RETRY_DELAY=2

# SoFIFA
SOFIFA_MAX_RETRIES=3
SOFIFA_RETRY_DELAY=5

# Understat
UNDERSTAT_MAX_RETRIES=3
UNDERSTAT_RETRY_DELAY=5

# =============================================================================
# PROXY CONFIGURATION (optionnel, pour éviter les blocages)
# =============================================================================

# Proxy HTTP/HTTPS (format: http://user:pass@host:port)
HTTP_PROXY=
HTTPS_PROXY=

# Rotation de proxy (liste séparée par des virgules)
PROXY_POOL=

# =============================================================================
# LOGGING
# =============================================================================

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Format de log (json ou text)
LOG_FORMAT=json

# Fichier de log (laisser vide pour stdout)
LOG_FILE=/workspace/soccer_analytics/logs/app.log

# =============================================================================
# INGESTION SETTINGS
# =============================================================================

# Délai entre les requêtes pour respecter les CGU (secondes)
REQUEST_DELAY=2

# Nombre maximum de matchs à ingérer par batch
BATCH_SIZE=50

# Activer/désactiver le cache
USE_CACHE=true

# Forcer la mise à jour du cache après X jours
CACHE_MAX_AGE_DAYS=7

# =============================================================================
# LIGUES PAR DEFAUT A INGERER
# =============================================================================

# Format: NOM_LIGUE:SAISON
# Exemples:
DEFAULT_LEAGUES=EPL:2023-2024,ESP-La Liga:2023-2024,ITA-Serie A:2023-2024,GER-Bundesliga:2023-2024,FRA-Ligue 1:2023-2024

# Sources activées par défaut (séparées par des virgules)
# Options: fbref, whoscored, sofascore, espn, matchhistory, clubelo, sofifa, understat
ACTIVE_SOURCES=fbref,matchhistory,clubelo

# =============================================================================
# SCHEDULING (pour les mises à jour automatiques)
# =============================================================================

# Activer le scheduler
ENABLE_SCHEDULER=false

# Fréquence de mise à jour (cron expression ou intervalle)
# Ex: "0 2 * * *" = tous les jours à 2h du matin
UPDATE_SCHEDULE=0 2 * * *

# =============================================================================
# ENVIRONNEMENT
# =============================================================================

ENVIRONMENT=development
# ENVIRONMENT=production
